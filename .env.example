# Base del API:
# - URL absoluta (sin proxy): `http://localhost:3004/api`
# - Misma máquina en dev con proxy: `/api` y define BACKEND_PORT igual que PORT del backend
VITE_API_URL=/api

# Puerto del backend (solo lectura en vite.config; debe coincidir con PORT del .env del API)
BACKEND_PORT=3004

# Puerto de `vite` (dev y `vite preview`; no usar --port en PM2/deploy para que aplique)
VITE_PORT=4200
