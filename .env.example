# Base del API: siempre `http://` o `https://` si apuntas a IP/host (sin esquema,
# el navegador lo trata como ruta y rompe las peticiones). Misma máquina + proxy: `/api`
VITE_API_URL=http://localhost:3002/api

# Puerto de `vite` (dev y `vite preview`; no usar --port en PM2/deploy para que aplique)
VITE_PORT=4200
