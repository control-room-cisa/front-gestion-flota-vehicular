# Base del API:
# - URL absoluta (sin proxy): `http://localhost:3004/api`
# - Misma máquina en dev con proxy: `/api` y define BACKEND_PORT igual que PORT del backend
VITE_API_URL=/api

# Puerto del backend (solo lectura en vite.config; debe coincidir con PORT del .env del API)
BACKEND_PORT=3004

# Puerto del front (dev y `vite preview`). Debe ser distinto del PORT del backend.
VITE_PORT=3005

# Hostnames permitidos por el dev server / preview (lista separada por comas).
# Necesario si accedes por un host que no sea localhost (Cloudflare Tunnel, etc.).
# Prefijo ".dominio.ext" permite ese dominio y todos los subdominios (ver server.allowedHosts en Vite).
# ALLOWED_HOSTS=.trycloudflare.com
